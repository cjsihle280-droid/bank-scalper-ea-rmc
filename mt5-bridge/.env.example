# Experimental Dockerfile for MT5 Bridge
# Note: MT5 requires Windows, this uses Wine which may have compatibility issues

FROM python:3.11-slim

# Install system dependencies for Wine and MT5
RUN apt-get update && apt-get install -y \
    wine \
    xvfb \
    wget \
    gnupg \
    software-properties-common \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Wine dependencies
RUN dpkg --add-architecture i386 && \
    apt-get update && \
    apt-get install -y wine32

# Set up virtual display for headless operation
ENV DISPLAY=:99
ENV WINEPREFIX=/root/.wine
ENV WINEARCH=win32

# Create working directory
WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Install Python dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Copy application code
COPY . .

# Create logs directory
RUN mkdir -p logs

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Expose port
EXPOSE 8000

# Start Xvfb and the application
CMD ["sh", "-c", "Xvfb :99 -screen 0 1024x768x24 > /dev/null 2>&1 & sleep 2 && python main.py"]</content>
